{
  "name": "engawa",
  "version": "0.1.0",
  "bin": {
    "engawa": "./dist/cli.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "scripts": {
    "dev": "tsx src/cli.ts --no-claude",
    "dev:claude": "tsx src/cli.ts",
    "gen:agents": "tsx src/cli.ts init",
    "logs": "tsx src/cli.ts logs -f",
    "e2e": "ENGAWA_DEBUG=1 tsx src/e2e.ts",
    "build": "tsup",
    "lint": "oxlint -c ../../packages/oxc-config/oxlint.json src/",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "knip": "knip"
  },
  "dependencies": {
    "@hono/node-server": "1.19.11",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@engawa/typescript-config": "workspace:*",
    "@types/node": "25.5.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "vitest": "4.1.0"
  }
}
