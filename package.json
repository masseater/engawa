{
  "name": "engawa-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "oxfmt -c packages/oxc-config/.oxfmtrc .",
    "format:check": "oxfmt -c packages/oxc-config/.oxfmtrc --check .",
    "validate": "turbo build && turbo typecheck && turbo lint && oxfmt -c packages/oxc-config/.oxfmtrc --check . && turbo test"
  },
  "dependencies": {
    "engawa": "workspace:*"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev",
    "knip": "^5.88.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^0.16.10",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.6.5",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
